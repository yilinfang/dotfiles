# Window
window-width = 100
window-height = 30
window-padding-balance = true
window-padding-color = extend

# Font
font-family = ""
font-family = Maple Mono NF CN # CJK and symbols
font-family = Noto Color Emoji # Emojis
font-family = Symbols Nerd Font Mono # Fall back of symbols
font-size = 14

# Theme
theme = catppuccin-mocha

# MacOS
quit-after-last-window-closed = true
## Fix alt+arrow
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+f=esc:f
keybind = alt+b=esc:b
macos-option-as-alt = left
