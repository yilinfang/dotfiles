# Window
window-width = 100
window-height = 30
window-padding-balance = true
window-padding-color = extend

# Theme
theme = iTerm2 Tango Dark

# Background
# background-opacity = 0.9
# background-blur-radius = 20
# background = #000000

# Font
# font-family = ""
# font-family = JetBrains Mono
# font-family-bold = JetBrains Mono
# font-family-italic = Maple Mono
# font-family-bold-italic = Maple Mono
# font-family = Maple Mono CN # CJK
# font-family = Noto Color Emoji # Emojis
# font-family = Symbols Nerd Font Mono # Symbols
# font-size = 15

# Font
font-family = ""
font-family = JetMaple Mono
font-family = Noto Color Emoji # Emojis
font-family = Symbols Nerd Font Mono # Symbols
font-size = 15

# MacOS
quit-after-last-window-closed = true
## Fix alt+arrow
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+f=esc:f
keybind = alt+b=esc:b
macos-option-as-alt = left
