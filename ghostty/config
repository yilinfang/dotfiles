# Window
window-width = 100
window-height = 30
window-padding-balance = true
window-padding-color = extend

# Font
font-family = JetMaple Mono
font-family = Noto Color Emoji # Emojis
font-family = Symbols Nerd Font Mono # Symbols
font-size = 15

# MacOS
quit-after-last-window-closed = true

## Fix alt+arrow
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+f=esc:f
keybind = alt+b=esc:b
macos-option-as-alt = left

# Theme
# Tokyo Night Moon
# From https://github.com/folke/tokyonight.nvim/blob/main/extras/tmux/tokyonight_moon.tmux
palette = 0=#1b1d2b
palette = 1=#ff757f
palette = 2=#c3e88d
palette = 3=#ffc777
palette = 4=#82aaff
palette = 5=#c099ff
palette = 6=#86e1fc
palette = 7=#828bb8
palette = 8=#444a73
palette = 9=#ff8d94
palette = 10=#c7fb6d
palette = 11=#ffd8ab
palette = 12=#9ab8ff
palette = 13=#caabff
palette = 14=#b2ebff
palette = 15=#c8d3f5

background = #222436
foreground = #c8d3f5
cursor-color = #c8d3f5
selection-background = #2d3f76
selection-foreground = #c8d3f5
## Make window transparent
background-opacity = 0.9
background-blur-radius = 20
