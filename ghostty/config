# Window
window-padding-balance = true
window-width = 100
window-height = 30
quit-after-last-window-closed = true

# Font
font-family = ""
font-family = "Maple Mono NF CN"
font-family = "Noto Color Emoji"
font-size = 15

# Theme
theme = tokyonight

# MacOS
# Fix alt+arrow
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+f=esc:f
keybind = alt+b=esc:b
macos-option-as-alt = true
