" Only support Vim 9+
if v:version < 900
  finish
endif

" Use space as leader key
let g:mapleader = "\<Space>"

" Options
set nocompatible
filetype plugin indent on
syntax on
set number
set mouse=a
set autoread
set hlsearch
set incsearch
set ignorecase
set smartcase
set autoindent
set smartindent
set list
set listchars=tab:▸\ ,trail:·,extends:→,precedes:←,nbsp:␣
set termguicolors
" HACK: Fix vim's background color erase
" Source: https://sunaku.github.io/vim-256color-bce.html
if &term =~ '256color'
  " disable Background Color Erase (BCE) so that color schemes
  " render properly when inside 256-color tmux and GNU screen.
  " see also http://snk.tuxfamily.org/log/vim-256color-bce.html
  set t_ut=
endif

" Keymaps
nnoremap <leader>/ :noh<CR>
nnoremap <leader>r :e!<CR>
vnoremap <leader>y "+y<CR>

" Autogroups
" Resize splits if window got resized
augroup resize_splits
  autocmd!
  autocmd VimResized * wincmd =
augroup END

" Load offical packages
" osc52 support when inside SSH or tmux
if exists('$SSH_CONNECTION') || exists('$TMUX')
  packadd osc52
  let g:osc52_force_avail = v:true
  let g:osc52_disable_paste = v:true
  set clipmethod^=osc52
endif

" Load my own plugins
" Copy code reference
function! s:CopySelectionRef(relative)
  let l:filepath = a:relative ? expand('%:.') : expand('%:p')
  let l:line1 = line("'<")
  let l:line2 = line("'>")
  let l:start_line = min([l:line1, l:line2])
  let l:end_line = max([l:line1, l:line2])
  if l:start_line == l:end_line
    let l:ref = printf('%s:%d', l:filepath, l:start_line)
  else
    let l:ref = printf('%s:%d-%d', l:filepath, l:start_line, l:end_line)
  endif
  call setreg('+', l:ref)
  echomsg 'Copied: ' . l:ref
endfunction

xnoremap <leader>cr :<C-u>call <SID>CopySelectionRef(1)<CR>
xnoremap <leader>cR :<C-u>call <SID>CopySelectionRef(0)<CR>

" Check if vim-plug is installed
" You can install it via:
"  curl -fLo ~/.vim/autoload/plug.vim --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
let data_dir = '$HOME/.vim'
if empty(glob(data_dir . '/autoload/plug.vim'))
  finish
endif

" Load third-party plugins
call plug#begin()
  Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
  Plug 'junegunn/fzf.vim'
  Plug 'junegunn/seoul256.vim'
  Plug 'sheerun/vim-polyglot'
  Plug 'tpope/vim-commentary'
  Plug 'tpope/vim-fugitive'
  " No need for vim-sleuth since vim-ployglot achieves same funcionality
  " Plug 'tpope/vim-sleuth'
call plug#end()

" Config third-party plugins
" seoul256
let g:seoul256_background = 233
colorscheme seoul256
set background=dark
