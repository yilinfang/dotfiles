set nocompatible
filetype on
filetype plugin on
filetype indent on
syntax on
set number
set mouse=a
set hlsearch
set incsearch
set ignorecase
set smartcase
set autoindent
set smarttab
set nowrap
set showcmd
set noshowmatch
set list
set listchars=tab:▸\ ,trail:·,nbsp:␣
" Enable termguicolors if terminal supports it
if has("termguicolors")
  set termguicolors
endif
" Resize splits if window got resized
augroup resize_splits
  autocmd!
  autocmd VimResized * wincmd =
augroup END
