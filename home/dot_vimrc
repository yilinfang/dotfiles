set nocompatible
filetype on
filetype plugin on
filetype indent on
syntax on
set number
set mouse=a
set hlsearch
set incsearch
set ignorecase
set smartcase
set autoindent
set smarttab
set nowrap
set showcmd
set noshowmatch
set list
set listchars=tab:▸\ ,trail:·,nbsp:␣
" Resize splits if window got resized
augroup resize_splits
  autocmd!
  autocmd VimResized * wincmd =
augroup END
" Enable termguicolors if terminal supports it
if has("termguicolors")
  set termguicolors
endif
" Check if the unokai colorscheme file exists in the runtime path
if !empty(globpath(&rtp, "colors/unokai.vim"))
  colorscheme unokai
else
  " Fallback torte
  colorscheme torte
endif
